      "import": "./dist/controlCoreMiddleware.js",
      "types": "./dist/controlCoreMiddleware.d.ts"
    },
    "./identityResolver": {
      "import": "./dist/identityResolver.js",
      "types": "./dist/identityResolver.d.ts"
    },
    "./clusters": {
      "import": "./dist/clusters.js",
      "types": "./dist/clusters.d.ts"
    },
    "./conduits": {
      "import": "./dist/conduits.js",
      "types": "./dist/conduits.d.ts"
    },
    "./conduitGovernor": {
      "import": "./dist/conduitGovernor.js",
      "types": "./dist/conduitGovernor.d.ts"
    },
    "./deadLetter": {
      "import": "./dist/deadLetter.js",
      "types": "./dist/deadLetter.d.ts"
