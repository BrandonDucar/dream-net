{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "./dist",
        "rootDir": ".",
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "module": "ESNext",
        "moduleResolution": "bundler",
        "types": [
            "node"
        ],
        "skipLibCheck": true
    },
    "include": [
        "index.ts",
        "src/**/*",
        "logic/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ],
    "references": [
        { "path": "../dreamnet-types" },
        { "path": "../dreamnet-metrics-core" },
        { "path": "../dreamnet-cost-core" },
        { "path": "../spider-web-core" },
        { "path": "../dreamnet-voice-twilio" }
    ]
}