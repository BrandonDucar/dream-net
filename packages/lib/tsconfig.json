{
    "extends": "../../tsconfig.base.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": ".",
        "composite": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "module": "Node16",
        "moduleResolution": "Node16",
        "types": [
            "node"
        ],
        "skipLibCheck": true
    },
    "include": [
        "index.ts",
        "*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}