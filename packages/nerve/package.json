{
  "name": "@dreamnet/nerve",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./bus": {
      "import": "./dist/bus.js",
      "types": "./dist/bus.d.ts"
    },
    "./factory": {
      "import": "./dist/factory.js",
      "types": "./dist/factory.d.ts"
    },
    "./subscribers": {
      "import": "./dist/subscribers.js",
      "types": "./dist/subscribers.d.ts"
    },
    "./init": {
      "import": "./dist/init.js",
      "types": "./dist/init.d.ts"
    },
    "./types": {
      "import": "./dist/types.js",
      "types": "./dist/types.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dreamnet/types": "workspace:*",
    "@dreamnet/dreamstate": "workspace:*",
    "kafkajs": "^2.2.4"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
