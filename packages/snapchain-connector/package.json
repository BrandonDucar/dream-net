{
    "name": "@dreamnet/snapchain-connector",
    "version": "1.0.0",
    "description": "DreamNet Farcaster Snapchain Connector via gRPC",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "scripts": {
        "build": "tsc",
        "proto:gen": "proto-loader-gen-types --longs=String --enums=String --defaults --oneofs --grpcLib=@grpc/grpc-js --outDir=src/generated proto/definitions/*.proto"
    },
    "dependencies": {
        "@grpc/grpc-js": "^1.10.1",
        "@grpc/proto-loader": "^0.7.10",
        "protobufjs": "^7.2.5"
    },
    "devDependencies": {
        "typescript": "^5.3.3",
        "@types/node": "^20.0.0"
    }
}
