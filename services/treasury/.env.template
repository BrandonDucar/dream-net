# Treasury Service Configuration Template

# Server Configuration
PORT=3210
NODE_ENV=development

# Base Chain Treasury Address (where USDC settlement flows)
TREASURY_ADDRESS=0x742d35Cc6634C0532925a3b844Bc9e7595f42bE

# Hot Sender Private Key (encrypted in production - use vault!)
# Format: 0x... (without 0x for env parsing)
HOT_SENDER_PK=set_in_vault_never_in_git

# Circle CCTP Configuration (for cross-chain settlements)
CIRCLE_API_KEY=set_in_vault_never_in_git
CIRCLE_ENTITY_SECRET=set_in_vault_never_in_git
CCTP_CONTRACT_ADDRESS=0xDB5492265f8019e6435cd995e6461FA7c369F270

# Sovereign Token (for /api/treasury/sovereign-override endpoint)
# This should be a long, random token rotated regularly
SOVEREIGN_BEARER_TOKEN=set_in_vault_never_in_git

# Daily Spending Caps (in USD)
TREASURY_DAILY_CAP=2000
TREASURY_PER_TRANSACTION_CAP=250

# RuntimeBridge Configuration
RUNTIME_BRIDGE_URL=http://localhost:3300
RUNTIME_BRIDGE_KEY=set_in_vault_never_in_git

# Economic Engine Integration
ECONOMIC_ENGINE_URL=http://localhost:3301
ECONOMIC_ENGINE_KEY=set_in_vault_never_in_git

# DreamShop Integration
DREAMSHOP_WEBHOOK_URL=http://localhost:3302/api/checkout/treasury-notify
DREAMSHOP_API_KEY=set_in_vault_never_in_git

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=json

# Monitoring & Observability
SENTRY_DSN=optional_sentry_error_tracking
DATADOG_API_KEY=optional_for_apm
PROM_METRICS_ENABLED=true
PROM_METRICS_PORT=9090

# Database Configuration (optional - for persistence beyond memory)
DB_CONNECTION_STRING=optional_postgres_for_settlement_ledger

# Feature Flags
FEATURE_CCTP_ENABLED=false
FEATURE_SOVEREIGN_OVERRIDE=true
FEATURE_DAILY_CAPS=true

# Deployment Context
DEPLOYMENT_ENV=local
DEPLOYMENT_REGION=us-east-1
